PORT=3000
HOST=127.0.0.1
NODE_ENV=development
MCP_ENDPOINT_PATH=/mcp
IMAGE_PROXY_PATH=/images/vicflora
IMAGE_PROXY_ALLOWED_HOSTS=vicflora-cdn.rbg.vic.gov.au,vicflora.rbg.vic.gov.au
PUBLIC_BASE_URL=http://localhost:3000
# Railway sets this automatically for public service domains.
RAILWAY_PUBLIC_DOMAIN=botany-production.up.railway.app

# Defaults to false unless NODE_ENV=production. Set explicitly to override.
AUTH_REQUIRED=false
BOTANY_MCP_TOKEN=generate-a-long-random-token
OAUTH_CLIENT_ID=botany-mcp
OAUTH_CLIENT_SECRET=generate-another-long-random-secret
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

VICFLORA_GRAPHQL_ENDPOINT=https://vicflora.rbg.vic.gov.au/graphql
VICFLORA_TIMEOUT_MS=12000
VICFLORA_CACHE_TTL_MS=300000
LOG_LEVEL=info
