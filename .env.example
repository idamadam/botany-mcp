PORT=3000
HOST=127.0.0.1
MCP_ENDPOINT_PATH=/mcp
PUBLIC_BASE_URL=http://localhost:3000

# Local development is intentionally easy. Set true in hosted environments.
AUTH_REQUIRED=false
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.au.auth0.com/
AUTH0_AUDIENCE=https://botany-mcp.example.com
AUTH_REQUIRED_SCOPES=plants:read

VICFLORA_GRAPHQL_ENDPOINT=https://vicflora.rbg.vic.gov.au/graphql
VICFLORA_TIMEOUT_MS=12000
VICFLORA_CACHE_TTL_MS=300000
LOG_LEVEL=info
